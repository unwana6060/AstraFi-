# Environment variables for Hardhat Arbitrum deployment
# DO NOT commit your real private key or secret API keys to GitHub!

# Your Ethereum wallet private key (without the '0x' prefix)
PRIVATE_KEY=your_private_key_here

# Arbitrum RPC provider URLs (Get yours at Alchemy, Infura, or QuickNode)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_MAINNET_RPC_URL=https://arb1.arbitrum.io/rpc

# Arbiscan / Etherscan API key for contract verification
